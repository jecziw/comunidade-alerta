# =============================================================================
# Comunidade Alerta — variáveis de ambiente
# Copie para .env e preencha com valores reais.
# NUNCA versione o .env — ele está no .gitignore.
# =============================================================================

# --- Banco de dados ---
POSTGRES_DB=comunidade_alerta
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque_em_producao

# --- Backend ---
PORT=3000
NODE_ENV=production
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=troque_em_producao

# --- Imagem (usado no docker-compose de produção) ---
IMAGE_TAG=latest
