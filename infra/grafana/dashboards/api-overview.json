{
  "title": "Comunidade Alerta — API",
  "uid": "comunidade-alerta-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requisições por segundo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_request_duration_ms_count[1m])",
          "legendFormat": "{{method}} {{route}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latência p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket[5m]))",
          "legendFormat": "p95 {{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Erros 5xx por segundo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_request_duration_ms_count{status_code=~\"5..\"}[1m])",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Uso de memória Node.js (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "RSS"
        }
      ]
    }
  ]
}
