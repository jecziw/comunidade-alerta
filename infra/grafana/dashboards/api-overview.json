{
  "title": "Comunidade Alerta — API",
  "uid": "comunidade-alerta-api",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requisições por segundo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(http_request_duration_ms_count[1m])", "legendFormat": "{{method}} {{route}} {{status_code}}" }]
    },
    {
      "id": 2,
      "title": "Latência p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket[5m]))", "legendFormat": "p95 {{route}}" }]
    },
    {
      "id": 3,
      "title": "Taxa de erros 5xx por segundo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(http_request_duration_ms_count{status_code=~\"5..\"}[1m])", "legendFormat": "{{route}}" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.05 }] } } }
    },
    {
      "id": 4,
      "title": "Uso de memória Node.js (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "process_resident_memory_bytes / 1024 / 1024", "legendFormat": "RSS" }]
    },
    {
      "id": 5,
      "title": "Erros 5xx (última hora)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(increase(http_request_duration_ms_count{status_code=~\"5..\"}[1h]))", "legendFormat": "Erros 5xx" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 6,
      "title": "Latência p95 atual (ms)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket[5m])) by (le))", "legendFormat": "p95" }],
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 1000 }] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 7,
      "title": "Uptime da API",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "targets": [{ "expr": "process_uptime_seconds", "legendFormat": "uptime" }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 8,
      "title": "Taxa de sucesso 2xx (%)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_request_duration_ms_count{status_code=~\"2..\"}[5m])) / sum(rate(http_request_duration_ms_count[5m])) * 100", "legendFormat": "sucesso %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 99 }] }, "color": { "mode": "thresholds" } } }
    }
  ]
}
